{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["mergestat"],
  "title": "MergeStat — Repo Syncs",
  "uid": "mergestat-syncs",
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Sync queue depth by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mergestat_repo_sync_queue_jobs{status=\"QUEUED\"}", "legendFormat": "queued" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mergestat_repo_sync_queue_jobs{status=\"RUNNING\"}", "legendFormat": "running" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mergestat_repo_sync_queue_jobs{status=\"FAILED\"}", "legendFormat": "failed" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Oldest queued (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 1800 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mergestat_repo_sync_oldest_queued_seconds" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mergestat_repo_sync_failed_24h" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Completed (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 9 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mergestat_repo_sync_completed_24h" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Running jobs",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 9 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mergestat_repo_sync_queue_jobs{status=\"RUNNING\"}", "legendFormat": "running" }
      ]
    }
  ]
}
